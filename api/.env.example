PORT=8000
NODE_ENV=development

# Local SQLite (default when DB_HOST is empty)
SQLITE_PATH=./data/lotaya.sqlite

# Production: Aiven / Z.com MySQL (set DB_HOST to enable)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=lotaya

# Admin panel API key
ADMIN_API_KEY=change-me-in-production

# Point to MMK rates by tier
RATE_BRONZE=3
RATE_SILVER=3
RATE_GOLD=3
RATE_FIRE=4
RATE_DIAMOND=4
MIN_WITHDRAW_POINTS=500
WITHDRAW_STEP=500
