APP_NAME="Lotaya Shwe Oh"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Local Laragon MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lotaya
DB_USERNAME=root
DB_PASSWORD=

# Aiven / cloud MySQL (Render): use Service URI values separately — NOT "Host: ..., Port: ..."
# DB_PORT is usually 12046 (not 3306). DB_DATABASE is often defaultdb on Aiven.
# MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Lotaya business config ---
ADMIN_API_KEY=change-me-local-admin-key
ADMIN_PASSWORD=change-me-private-admin-password
ADMIN_PANEL_PATH=lso-private-change-me
# Optional: comma-separated IPs (your home/mobile public IP). Empty = allow all IPs.
ADMIN_ALLOWED_IPS=

RATE_BRONZE=3
RATE_SILVER=3
RATE_GOLD=3
RATE_FIRE=4
RATE_DIAMOND=4

MIN_WITHDRAW_POINTS=500
WITHDRAW_STEP=500

# Public exchange page (same server on Render/Z.com)
EXCHANGE_URL=http://localhost:8000/exchange
