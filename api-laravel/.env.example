APP_NAME="Lotaya Shwe Oh"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Local Laragon MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lotaya
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Lotaya business config ---
ADMIN_API_KEY=change-me-local-admin-key

RATE_BRONZE=3
RATE_SILVER=3
RATE_GOLD=3
RATE_FIRE=4
RATE_DIAMOND=4

MIN_WITHDRAW_POINTS=500
WITHDRAW_STEP=500

# Public exchange page (same server on Render/Z.com)
EXCHANGE_URL=http://localhost:8000/exchange
